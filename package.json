{
  "name": "akp-architekten-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host=0.0.0.0",
    "start": "node server.mjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test src/__tests__/*.test.tsx scripts/*.test.mjs",
    "smoke:server": "node scripts/smoke-server.mjs",
    "ci": "npm run lint && npm test && npm run build && npm run smoke:server"
  },
  "dependencies": {
    "express": "^4.21.2",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  }
}
